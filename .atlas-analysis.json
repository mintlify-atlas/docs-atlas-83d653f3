  "keyFeatures": [
    "Multi-stage bootrom exploit execution",
    "eMMC partition manipulation and GPT management",
    "RPMB downgrade for firmware rollback",
    "Fastboot and recovery mode forcing",
    "Device unlock and verification bypass",
    "Serial communication protocol for MediaTek devices"
  ],
  "publicApiSurface": [
    "bootrom-step.sh - Main exploit execution script",
    "boot-fastboot.sh - Force boot into fastboot mode",
    "boot-recovery.sh - Force boot into recovery mode",
    "gpt-fix.sh - Fix corrupted GPT partition table",
    "Device class - Python interface for device communication",
    "load_payload() - Load and execute bootrom payloads",
    "load_pl_payload() - Load preloader payload",
    "emmc_read()/emmc_write() - Direct eMMC access",
    "rpmb_read()/rpmb_write() - RPMB partition operations",
    "parse_gpt() - GPT partition table parser"
  ]
